<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ControlCatalog.Pages.NavigationPageStackPage">
  <DockPanel>
    <ScrollViewer DockPanel.Dock="Right" Width="260">
      <StackPanel Margin="12" Spacing="8">
        <TextBlock Text="Stack Management" FontWeight="SemiBold" FontSize="14" />

        <Button Content="Push New Page"
                HorizontalAlignment="Stretch"
                Click="OnPush" />
        <Button Content="Insert Before Current"
                HorizontalAlignment="Stretch"
                Click="OnInsert" />
        <Button Content="Remove Current Page"
                HorizontalAlignment="Stretch"
                Click="OnRemoveCurrent" />
        <Button Content="Pop to Root"
                HorizontalAlignment="Stretch"
                Click="OnPopToRoot" />

        <Separator />

        <TextBlock Text="Navigation Stack" FontWeight="SemiBold" FontSize="12" />
        <TextBlock x:Name="DepthLabel"
                   Text="Depth: 1"
                   Opacity="0.7"
                   FontSize="12" />

        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1"
                CornerRadius="4">
          <StackPanel x:Name="StackDisplay" Margin="4" Spacing="2" />
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border DockPanel.Dock="Right" Width="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />

    <Border Margin="12"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1"
            CornerRadius="6"
            ClipToBounds="True">
      <NavigationPage x:Name="DemoNav" />
    </Border>
  </DockPanel>
</UserControl>
