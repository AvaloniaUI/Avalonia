    <StreamGeometry x:Key="RedoIcon">M18.4,10.6C16.55,9 14.15,8 11.5,8C6.85,8 2.92,11.03 1.54,15.22L3.9,16C4.95,12.81 7.95,10.5 11.5,10.5C13.45,10.5 15.23,11.22 16.62,12.38L13,16H22V7L18.4,10.6Z</StreamGeometry>
  </UserControl.Resources>

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="0,0,0,16">
      <TextBlock Classes="h2">A toolbar that supports primary and secondary commands with optional overflow menu.</TextBlock>

      <!-- Options -->
      <StackPanel Spacing="8">
        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,4">
            <TextBlock Text="Label Position:" VerticalAlignment="Center" />
            <ComboBox x:Name="LabelPositionCombo" SelectedIndex="0"
                      SelectionChanged="OnLabelPositionChanged" Width="120">
              <ComboBoxItem Content="Bottom" />
              <ComboBoxItem Content="Right" />
              <ComboBoxItem Content="Collapsed" />
            </ComboBox>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,4">
            <TextBlock Text="Overflow Button:" VerticalAlignment="Center" />
            <ComboBox x:Name="OverflowCombo" SelectedIndex="0"
                      SelectionChanged="OnOverflowChanged" Width="120">
              <ComboBoxItem Content="Auto" />
              <ComboBoxItem Content="Visible" />
              <ComboBoxItem Content="Collapsed" />
            </ComboBox>
          </StackPanel>
        </WrapPanel>
        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
          <CheckBox x:Name="IsStickyCheck" Content="IsSticky" Margin="0,0,16,0"
                    Click="OnIsStickyToggled" />
          <CheckBox x:Name="IsDynamicOverflowCheck" Content="Dynamic Overflow" Margin="0,0,16,0"
                    Click="OnDynamicOverflowToggled" />
          <Button Content="+ Add Primary" Click="OnAddCommand" Margin="0,0,8,0" />
          <Button Content="- Remove Last" Click="OnRemoveCommand" />
        </WrapPanel>
      </StackPanel>

      <!-- Main CommandBar -->
      <CommandBar x:Name="MainCommandBar">
        <CommandBar.Content>
          <TextBlock Text="Document" VerticalAlignment="Center" Margin="8,0" />
        </CommandBar.Content>
        <CommandBar.PrimaryCommands>
          <AppBarButton Label="New">
            <AppBarButton.Icon>
              <PathIcon Data="{StaticResource AddIcon}" />
            </AppBarButton.Icon>
          </AppBarButton>
          <AppBarButton Label="Save">
            <AppBarButton.Icon>
              <PathIcon Data="{StaticResource SaveIcon}" />
            </AppBarButton.Icon>
          </AppBarButton>
          <AppBarSeparator />
          <AppBarToggleButton x:Name="BoldToggle" Label="Bold">
            <AppBarToggleButton.Icon>
              <PathIcon Data="{StaticResource BoldIcon}" />
            </AppBarToggleButton.Icon>
          </AppBarToggleButton>
          <AppBarToggleButton x:Name="ItalicToggle" Label="Italic">
            <AppBarToggleButton.Icon>
              <PathIcon Data="{StaticResource ItalicIcon}" />
            </AppBarToggleButton.Icon>
          </AppBarToggleButton>
          <AppBarSeparator />
          <AppBarButton Label="Share">
            <AppBarButton.Icon>
              <PathIcon Data="{StaticResource ShareIcon}" />
            </AppBarButton.Icon>
          </AppBarButton>
        </CommandBar.PrimaryCommands>
        <CommandBar.SecondaryCommands>
          <AppBarButton Label="Export">
            <AppBarButton.Icon>
              <PathIcon Data="{StaticResource ExportIcon}" />
            </AppBarButton.Icon>
          </AppBarButton>
          <AppBarButton Label="Print">
            <AppBarButton.Icon>
              <PathIcon Data="{StaticResource PrintIcon}" />
            </AppBarButton.Icon>
          </AppBarButton>
          <AppBarSeparator />
          <AppBarButton Label="Delete">
            <AppBarButton.Icon>
              <PathIcon Data="{StaticResource DeleteIcon}" />
            </AppBarButton.Icon>
          </AppBarButton>
        </CommandBar.SecondaryCommands>
      </CommandBar>

      <!-- Label positions side-by-side -->
      <TextBlock Text="Label Positions" FontWeight="SemiBold" />
      <WrapPanel Orientation="Horizontal">
        <StackPanel Spacing="4" Margin="0,0,16,0">
          <TextBlock Text="Bottom (default)" FontSize="12" Opacity="0.7" />
          <CommandBar DefaultLabelPosition="Bottom" OverflowButtonVisibility="Collapsed">
            <AppBarButton Label="New">
              <AppBarButton.Icon><PathIcon Data="{StaticResource AddIcon}" /></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Save">
              <AppBarButton.Icon><PathIcon Data="{StaticResource SaveIcon}" /></AppBarButton.Icon>
            </AppBarButton>
          </CommandBar>
        </StackPanel>
        <StackPanel Spacing="4" Margin="0,0,16,0">
          <TextBlock Text="Right" FontSize="12" Opacity="0.7" />
          <CommandBar DefaultLabelPosition="Right" OverflowButtonVisibility="Collapsed">
            <AppBarButton Label="New">
              <AppBarButton.Icon><PathIcon Data="{StaticResource AddIcon}" /></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Save">
              <AppBarButton.Icon><PathIcon Data="{StaticResource SaveIcon}" /></AppBarButton.Icon>
            </AppBarButton>
          </CommandBar>
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Collapsed (icon only)" FontSize="12" Opacity="0.7" />
          <CommandBar DefaultLabelPosition="Collapsed" OverflowButtonVisibility="Collapsed">
            <AppBarButton ToolTip.Tip="New">
              <AppBarButton.Icon><PathIcon Data="{StaticResource AddIcon}" /></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton ToolTip.Tip="Save">
              <AppBarButton.Icon><PathIcon Data="{StaticResource SaveIcon}" /></AppBarButton.Icon>
            </AppBarButton>
          </CommandBar>
        </StackPanel>
      </WrapPanel>

      <!-- Toggle buttons -->
      <TextBlock Text="Toggle Buttons" FontWeight="SemiBold" />
      <CommandBar OverflowButtonVisibility="Collapsed">
        <AppBarToggleButton Label="Bold">
          <AppBarToggleButton.Icon><PathIcon Data="{StaticResource BoldIcon}" /></AppBarToggleButton.Icon>
        </AppBarToggleButton>
        <AppBarToggleButton Label="Italic">
          <AppBarToggleButton.Icon><PathIcon Data="{StaticResource ItalicIcon}" /></AppBarToggleButton.Icon>
        </AppBarToggleButton>
      </CommandBar>

      <!-- Compact icon-only bar -->
      <TextBlock Text="Compact Bar (icon only, no overflow button)" FontWeight="SemiBold" />
      <CommandBar DefaultLabelPosition="Collapsed" OverflowButtonVisibility="Collapsed">
        <AppBarButton ToolTip.Tip="New">
          <AppBarButton.Icon><PathIcon Data="{StaticResource AddIcon}" /></AppBarButton.Icon>
        </AppBarButton>
        <AppBarButton ToolTip.Tip="Save">
          <AppBarButton.Icon><PathIcon Data="{StaticResource SaveIcon}" /></AppBarButton.Icon>
        </AppBarButton>
        <AppBarSeparator />
        <AppBarButton ToolTip.Tip="Undo">
          <AppBarButton.Icon><PathIcon Data="{StaticResource UndoIcon}" /></AppBarButton.Icon>
        </AppBarButton>
        <AppBarButton ToolTip.Tip="Redo">
          <AppBarButton.Icon><PathIcon Data="{StaticResource RedoIcon}" /></AppBarButton.Icon>
        </AppBarButton>
        <AppBarSeparator />
        <AppBarToggleButton ToolTip.Tip="Bold">
          <AppBarToggleButton.Icon><PathIcon Data="{StaticResource BoldIcon}" /></AppBarToggleButton.Icon>
        </AppBarToggleButton>
        <AppBarToggleButton ToolTip.Tip="Italic">
          <AppBarToggleButton.Icon><PathIcon Data="{StaticResource ItalicIcon}" /></AppBarToggleButton.Icon>
        </AppBarToggleButton>
      </CommandBar>
    </StackPanel>
  </ScrollViewer>
</UserControl>
