<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ControlCatalog.Pages.DrawerPagePerformancePage"
             Loaded="OnControlLoaded"
             Unloaded="OnControlUnloaded">
  <Grid ColumnDefinitions="*,300">

    <DockPanel Grid.Column="0" Margin="16">
      <DockPanel DockPanel.Dock="Bottom" Margin="0,12,0,0" Height="140">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
          <TextBlock Text="Operation Log" FontSize="13" FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Button x:Name="ClearLogButton" Content="Clear" FontSize="11"
                  Padding="8,2" HorizontalAlignment="Right" Click="OnClearLog" />
        </DockPanel>
        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1" CornerRadius="4" ClipToBounds="True">
          <ScrollViewer x:Name="LogScrollViewer">
            <StackPanel x:Name="LogPanel" Spacing="0" />
          </ScrollViewer>
        </Border>
      </DockPanel>

      <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1" CornerRadius="8" ClipToBounds="True">
        <DrawerPage x:Name="DrawerPageControl">
          <DrawerPage.DrawerHeader>
            <Border Background="{DynamicResource SystemControlHighlightAccentBrush}" Padding="16">
              <StackPanel Spacing="4">
                <TextBlock Text="Menu" FontSize="20" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Select a page to swap detail" FontSize="12" Foreground="White" Opacity="0.7" />
              </StackPanel>
            </Border>
          </DrawerPage.DrawerHeader>

          <DrawerPage.Drawer>
            <StackPanel Margin="8" Spacing="4">
              <Button HorizontalAlignment="Stretch" Background="Transparent"
                      Click="OnMenuItemClick" Tag="Home">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Width="16" Height="16" Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" />
                  <TextBlock Text="Home" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button HorizontalAlignment="Stretch" Background="Transparent"
                      Click="OnMenuItemClick" Tag="Profile">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Width="16" Height="16" Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" />
                  <TextBlock Text="Profile" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button HorizontalAlignment="Stretch" Background="Transparent"
                      Click="OnMenuItemClick" Tag="Messages">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Width="16" Height="16" Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z" />
                  <TextBlock Text="Messages" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button HorizontalAlignment="Stretch" Background="Transparent"
                      Click="OnMenuItemClick" Tag="Settings">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Width="16" Height="16" Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" />
                  <TextBlock Text="Settings" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </StackPanel>
          </DrawerPage.Drawer>

          <DrawerPage.Content>
            <ContentPage x:Name="DetailPage" Header="Home">
              <StackPanel Margin="16" Spacing="8"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="DetailTitleText" Text="Home" FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="DetailDescriptionText"
                           Text="Select a menu item from the drawer to swap the detail page."
                           FontSize="14" Opacity="0.6" TextWrapping="Wrap" MaxWidth="400"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </ContentPage>
          </DrawerPage.Content>

          <DrawerPage.DrawerFooter>
            <Border Padding="16">
              <StackPanel Spacing="2">
                <TextBlock Text="Avalonia" FontSize="12" FontWeight="SemiBold" Opacity="0.6" />
                <TextBlock Text="v1.0.0" FontSize="11" Opacity="0.4" />
              </StackPanel>
            </Border>
          </DrawerPage.DrawerFooter>
        </DrawerPage>
      </Border>
    </DockPanel>

    <Border Grid.Column="1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1,0,0,0"
            Padding="16">
      <ScrollViewer>
        <StackPanel Spacing="12">

          <TextBlock Text="Metrics" FontSize="16" FontWeight="SemiBold"
                     Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />

          <TextBlock x:Name="CurrentDetailText" Text="Current Detail: Home" FontSize="13" />
          <TextBlock x:Name="SwapCountText" Text="Detail Swaps: 0" FontSize="13" />
          <TextBlock x:Name="LiveInstancesText" Text="Live Page Instances: 0" FontSize="13" />
          <TextBlock x:Name="TotalCreatedText" Text="Total Pages Created: 0" FontSize="13" />
          <DockPanel>
            <TextBlock x:Name="ManagedMemoryText" Text="Managed Heap: 0.0 MB" FontSize="13" />
            <TextBlock x:Name="MemoryDeltaText" Text="" FontSize="13" FontWeight="SemiBold"
                       Margin="6,0,0,0" />
          </DockPanel>
          <TextBlock x:Name="LastOpTimeText"     Text="Last Op: —"            FontSize="13" />

          <Separator Margin="0,4" />

          <TextBlock Text="Actions" FontSize="16" FontWeight="SemiBold"
                     Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />

          <Button Content="Swap Detail (New Page)"
                  HorizontalAlignment="Stretch" Click="OnSwapDetail" />
          <Button Content="Swap 5 Times"
                  HorizontalAlignment="Stretch" Click="OnSwap5" />
          <Button Content="Toggle Drawer"
                  HorizontalAlignment="Stretch" Click="OnToggleDrawer" />

          <Separator Margin="0,4" />

          <Button Content="Force GC + Refresh"
                  HorizontalAlignment="Stretch" Click="OnForceGC"
                  Background="{DynamicResource SystemControlHighlightAccentBrush}"
                  Foreground="White" />

          <CheckBox x:Name="AutoRefreshCheck" Content="Auto-refresh (2s)"
                    FontSize="13" IsCheckedChanged="OnAutoRefreshChanged" />

          <Separator Margin="0,4" />

          <TextBlock Text="Detail History" FontSize="16" FontWeight="SemiBold"
                     Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />

          <StackPanel x:Name="HistoryPanel" Spacing="4" />

        </StackPanel>
      </ScrollViewer>
    </Border>

  </Grid>
</UserControl>
