<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ControlCatalog.Pages.DrawerPageNavigationPage">
  <DockPanel>
    <ScrollViewer DockPanel.Dock="Right" Width="260">
      <StackPanel Margin="12" Spacing="8">
        <TextBlock Text="How it works" FontWeight="SemiBold" FontSize="16"
                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />

        <TextBlock Text="Master-detail pattern: the drawer is the master list; the detail is a NavigationPage with a CrossFadePageTransition."
                   TextWrapping="Wrap" FontSize="13" Opacity="0.8" />

        <Separator />

        <TextBlock Text="Pattern" FontWeight="SemiBold" FontSize="13" />
        <StackPanel Spacing="8">
          <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                     Text="&#x2022; DrawerPage wraps a NavigationPage as Detail" />
          <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                     Text="&#x2022; Menu selection pushes a new Page onto the stack" />
          <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                     Text="&#x2022; IsOpen two-way bound to ViewModel" />
          <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                     Text="&#x2022; CrossFadePageTransition on the NavigationPage" />
        </StackPanel>

        <Separator />

        <TextBlock Text="Gestures" FontWeight="SemiBold" FontSize="13" />
        <StackPanel Spacing="8">
          <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                     Text="&#x2022; Drag from left edge to open drawer" />
          <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                     Text="&#x2022; Drag left within pane to close" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <Border DockPanel.Dock="Right" Width="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />

    <Border Margin="12"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1"
            CornerRadius="6"
            ClipToBounds="True">
      <DrawerPage x:Name="DemoDrawer"
                  Header="Nav Integration"
                  DrawerLength="220">
        <DrawerPage.DrawerHeader>
          <Border Background="{DynamicResource SystemControlHighlightAccentBrush}" Padding="16,20">
            <StackPanel Spacing="2">
              <TextBlock Text="Navigation" FontSize="18" FontWeight="Bold" Foreground="White" />
              <TextBlock Text="Select a section below" FontSize="12" Foreground="White" Opacity="0.7" />
            </StackPanel>
          </Border>
        </DrawerPage.DrawerHeader>
        <DrawerPage.Drawer>
          <ListBox x:Name="DrawerMenu" Background="Transparent" Margin="4"
                   SelectionChanged="OnMenuSelectionChanged">
            <ListBoxItem>
              <StackPanel Orientation="Horizontal" Spacing="12" Margin="8,10">
                <PathIcon Width="18" Height="18"
                          Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" />
                <TextBlock Text="Home" VerticalAlignment="Center" FontSize="15" />
              </StackPanel>
            </ListBoxItem>
            <ListBoxItem>
              <StackPanel Orientation="Horizontal" Spacing="12" Margin="8,10">
                <PathIcon Width="18" Height="18"
                          Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z" />
                <TextBlock Text="Inbox" VerticalAlignment="Center" FontSize="15" />
              </StackPanel>
            </ListBoxItem>
            <ListBoxItem>
              <StackPanel Orientation="Horizontal" Spacing="12" Margin="8,10">
                <PathIcon Width="18" Height="18"
                          Data="M3,4H21V8H3V4M3,10H21V14H3V10M3,16H21V20H3V16Z" />
                <TextBlock Text="Sent" VerticalAlignment="Center" FontSize="15" />
              </StackPanel>
            </ListBoxItem>
            <ListBoxItem>
              <StackPanel Orientation="Horizontal" Spacing="12" Margin="8,10">
                <PathIcon Width="18" Height="18"
                          Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" />
                <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="15" />
              </StackPanel>
            </ListBoxItem>
          </ListBox>
        </DrawerPage.Drawer>
        <DrawerPage.Content>
          <NavigationPage x:Name="DetailNav">
            <NavigationPage.PageTransition>
              <CrossFade Duration="0:0:0.3" />
            </NavigationPage.PageTransition>
          </NavigationPage>
        </DrawerPage.Content>
        <DrawerPage.DrawerFooter>
          <Border Padding="16"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                  BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <PathIcon Width="14" Height="14"
                        Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                        Opacity="0.5" />
              <TextBlock Text="My Account" FontSize="12" Opacity="0.6" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </DrawerPage.DrawerFooter>
      </DrawerPage>
    </Border>
  </DockPanel>
</UserControl>
