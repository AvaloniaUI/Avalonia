<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ControlCatalog.Pages.DrawerPageCustomizationPage"
             Loaded="OnControlLoaded">
  <DockPanel>
    <ScrollViewer DockPanel.Dock="Right" Width="280">
      <StackPanel Margin="12" Spacing="8">
        <TextBlock Text="Configuration" FontWeight="SemiBold" FontSize="16"
                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />

        <TextBlock Text="Actions" FontSize="13" FontWeight="SemiBold" />
        <Button Content="Toggle Drawer" Click="OnToggleDrawer" HorizontalAlignment="Stretch" />

        <Separator />

        <TextBlock Text="Behavior" FontSize="13" FontWeight="SemiBold" />
        <ComboBox x:Name="BehaviorCombo" SelectedIndex="0"
                  SelectionChanged="OnBehaviorChanged" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="Default" />
          <ComboBoxItem Content="Flyout" />
          <ComboBoxItem Content="Locked" />
          <ComboBoxItem Content="Disabled" />
        </ComboBox>

        <TextBlock Text="Layout" FontSize="12" Opacity="0.7" />
        <ComboBox x:Name="LayoutCombo" SelectedIndex="0"
                  SelectionChanged="OnLayoutChanged" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="Overlay" />
          <ComboBoxItem Content="Split" />
          <ComboBoxItem Content="CompactOverlay" />
          <ComboBoxItem Content="CompactInline" />
        </ComboBox>

        <TextBlock Text="Placement" FontSize="12" Opacity="0.7" />
        <ComboBox x:Name="PlacementCombo" SelectedIndex="0"
                  SelectionChanged="OnPlacementChanged" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="Left" />
          <ComboBoxItem Content="Right" />
          <ComboBoxItem Content="Top" />
          <ComboBoxItem Content="Bottom" />
        </ComboBox>

        <CheckBox x:Name="GestureCheck" Content="Gesture Enabled" IsChecked="True" Click="OnGestureToggled" />

        <Separator />

        <TextBlock Text="Appearance" FontSize="13" FontWeight="SemiBold" />

        <TextBlock Text="Drawer Length" FontSize="12" Opacity="0.7" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Slider x:Name="DrawerLengthSlider" Minimum="150" Maximum="400" Value="260"
                  Width="150" ValueChanged="OnDrawerLengthChanged" />
          <TextBlock x:Name="DrawerLengthText" Text="260" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Text="Drawer Background" FontSize="12" Opacity="0.7" />
        <ComboBox x:Name="DrawerBgCombo" SelectedIndex="0"
                  SelectionChanged="OnDrawerBgChanged" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="Default" />
          <ComboBoxItem Content="SlateBlue" />
          <ComboBoxItem Content="DarkCyan" />
          <ComboBoxItem Content="DarkRed" />
          <ComboBoxItem Content="DarkGreen" />
        </ComboBox>

        <TextBlock Text="Header Background" FontSize="12" Opacity="0.7" />
        <ComboBox x:Name="HeaderBgCombo" SelectedIndex="0"
                  SelectionChanged="OnHeaderBgChanged" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="Accent" />
          <ComboBoxItem Content="DodgerBlue" />
          <ComboBoxItem Content="Orange" />
          <ComboBoxItem Content="Teal" />
          <ComboBoxItem Content="Purple" />
        </ComboBox>

        <TextBlock Text="Footer Background" FontSize="12" Opacity="0.7" />
        <ComboBox x:Name="FooterBgCombo" SelectedIndex="0"
                  SelectionChanged="OnFooterBgChanged" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="None" />
          <ComboBoxItem Content="DimGray" />
          <ComboBoxItem Content="DarkSlateBlue" />
          <ComboBoxItem Content="DarkOliveGreen" />
          <ComboBoxItem Content="Maroon" />
        </ComboBox>

        <TextBlock Text="Drawer Icon" FontSize="12" Opacity="0.7" />
        <ComboBox x:Name="IconCombo" SelectedIndex="0"
                  SelectionChanged="OnIconChanged" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="3 lines" />
          <ComboBoxItem Content="2 lines" />
          <ComboBoxItem Content="4 squares" />
        </ComboBox>

        <TextBlock Text="Backdrop" FontSize="12" Opacity="0.7" />
        <ComboBox x:Name="BackdropCombo" SelectedIndex="0"
                  SelectionChanged="OnBackdropChanged" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="None" />
          <ComboBoxItem Content="Dark 40%" />
          <ComboBoxItem Content="Dark 70%" />
          <ComboBoxItem Content="Light 40%" />
        </ComboBox>

        <Separator />

        <TextBlock Text="Visibility" FontSize="13" FontWeight="SemiBold" />
        <CheckBox x:Name="ShowHeaderCheck" Content="Show Header" IsChecked="True" Click="OnShowHeaderToggled" />
        <CheckBox x:Name="ShowFooterCheck" Content="Show Footer" IsChecked="True" Click="OnShowFooterToggled" />
      </StackPanel>
    </ScrollViewer>

    <Border DockPanel.Dock="Right" Width="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />

    <Border Margin="12"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1"
            CornerRadius="6"
            ClipToBounds="True">
      <DrawerPage x:Name="DemoDrawer"
                  Header="Customization"
                  DrawerLength="260"
                  DrawerHeaderBackground="{DynamicResource SystemControlHighlightAccentBrush}">
        <DrawerPage.DrawerIconTemplate>
          <DataTemplate DataType="Geometry">
            <PathIcon Data="{Binding}" />
          </DataTemplate>
        </DrawerPage.DrawerIconTemplate>
        <DrawerPage.DrawerHeader>
          <Border x:Name="DrawerHeaderBorder" Padding="16">
            <StackPanel Spacing="4">
              <TextBlock Text="Menu" FontSize="20" FontWeight="Bold" Foreground="White" />
              <TextBlock Text="Navigation drawer" FontSize="12" Foreground="White" Opacity="0.7" />
            </StackPanel>
          </Border>
        </DrawerPage.DrawerHeader>
        <DrawerPage.Drawer>
          <StackPanel Margin="8" Spacing="4">
            <Button HorizontalAlignment="Stretch" Background="Transparent"
                    Click="OnMenuItemClick" Tag="Home">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <PathIcon Width="16" Height="16" Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" />
                <TextBlock Text="Home" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button HorizontalAlignment="Stretch" Background="Transparent"
                    Click="OnMenuItemClick" Tag="Profile">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <PathIcon Width="16" Height="16" Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" />
                <TextBlock Text="Profile" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button HorizontalAlignment="Stretch" Background="Transparent"
                    Click="OnMenuItemClick" Tag="Settings">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <PathIcon Width="16" Height="16" Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" />
                <TextBlock Text="Settings" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </DrawerPage.Drawer>
        <DrawerPage.Content>
          <ContentPage Header="Detail">
            <StackPanel Margin="16" Spacing="8">
              <TextBlock x:Name="DetailTitleText" Text="Home" FontSize="24" FontWeight="Bold" />
              <TextBlock x:Name="DetailDescriptionText"
                         Text="Use the configuration panel to customize drawer behavior and appearance."
                         TextWrapping="Wrap" />
            </StackPanel>
          </ContentPage>
        </DrawerPage.Content>
        <DrawerPage.DrawerFooter>
          <Border x:Name="DrawerFooterBorder" Padding="16">
            <StackPanel Spacing="2">
              <TextBlock Text="Avalonia" FontSize="12" FontWeight="SemiBold" Opacity="0.6" />
              <TextBlock Text="v1.0.0" FontSize="11" Opacity="0.4" />
            </StackPanel>
          </Border>
        </DrawerPage.DrawerFooter>
      </DrawerPage>
    </Border>
  </DockPanel>
</UserControl>
