<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ControlCatalog.Pages.TextBoxImePage">
  <ScrollViewer>
    <StackPanel Orientation="Vertical" Spacing="12" Margin="24,16,24,24">
      <WrapPanel Margin="-8,0">
        <StackPanel Orientation="Vertical" Spacing="8" Margin="8">
          <TextBox Text="IME small font" Width="240"
                   FontFamily="Comic Sans MS"
                   FontSize="10"
                   Foreground="Red"/>

          <TextBox Text="IME large font" Width="240"
                   FontFamily="Comic Sans MS"
                   FontSize="22"
                   Foreground="Red"/>

          <TextBox Text="IME disabled" Width="240"
                   FontFamily="Comic Sans MS"
                   InputMethod.IsInputMethodEnabled="False"
                   Foreground="Red"/>
        </StackPanel>
      </WrapPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
