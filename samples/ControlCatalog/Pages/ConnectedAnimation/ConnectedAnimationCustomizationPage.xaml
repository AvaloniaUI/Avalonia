<UserControl x:Class="ControlCatalog.Pages.ConnectedAnimationCustomizationPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel>
    <!-- Right sidebar -->
    <ScrollViewer DockPanel.Dock="Right" Width="280">
      <StackPanel Margin="16" Spacing="8">
        <TextBlock Text="Configuration" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
        <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.7"
                   Text="Customize the animation duration, configuration type, and shadow effect." />

        <TextBlock Text="How to use:" FontWeight="SemiBold" FontSize="13" Margin="0,8,0,0" />
        <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                   Text="1. Adjust the settings on the right&#10;2. Click a colored item in the list&#10;3. Watch the configured animation&#10;4. Click Back to reverse" />

        <Separator Margin="0,4" />

        <TextBlock Text="Duration" FontWeight="SemiBold" FontSize="13" />
        <Slider x:Name="DurationSlider" Minimum="100" Maximum="1500" Value="400" />
        <TextBlock x:Name="DurationLabel" Text="400 ms" FontSize="12" Opacity="0.7" />

        <Separator />

        <TextBlock Text="Animation Configuration" FontWeight="SemiBold" FontSize="13" />
        <ComboBox x:Name="ConfigCombo" SelectedIndex="0" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="Gravity" />
          <ComboBoxItem Content="Direct" />
          <ComboBoxItem Content="Basic" />
        </ComboBox>

        <CheckBox x:Name="ShadowCheck" Content="Shadow Enabled" IsChecked="True" />
        <TextBlock TextWrapping="Wrap" FontSize="11" Opacity="0.5"
                   Text="Adds a drop shadow that peeks mid-flight (Gravity only)." />

        <Separator />

        <TextBlock Text="Current" FontWeight="SemiBold" FontSize="13" />
        <TextBlock x:Name="CurrentLabel" Text="Gravity, 400ms" FontSize="12" Opacity="0.7" />

        <Separator />

        <TextBlock Text="Configurations" FontWeight="SemiBold" FontSize="13" />
        <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                   Text="Gravity: Natural motion with spring physics (default)" />
        <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                   Text="Direct: Straight line interpolation between positions" />
        <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                   Text="Basic: Simple linear transition" />

      </StackPanel>
    </ScrollViewer>

    <Border DockPanel.Dock="Right" Width="1"
            Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />

    <!-- Main content -->
    <DockPanel Margin="12">
      <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
        <TextBlock FontSize="20" FontWeight="Bold">
          <Run Text="Connected Animation" /><Run Text=" | " Foreground="Gray" /><Run Text="Customization" />
        </TextBlock>
        <TextBlock x:Name="SubtitleLabel" Text="Gravity, 400ms" FontSize="12" Opacity="0.5" />
      </StackPanel>

      <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1" CornerRadius="8" Padding="12" ClipToBounds="True">
        <Grid>
          <!-- List panel -->
          <StackPanel x:Name="ListPanel" Spacing="8">
            <Button x:Name="Item1" Click="OnItemClick" Tag="0" HorizontalAlignment="Stretch"
                    Padding="12" CornerRadius="6">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Border x:Name="Rect1" Width="48" Height="48" CornerRadius="8" Background="Red" />
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="Red Item" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="Tap to view details" FontSize="12" Opacity="0.5" />
                </StackPanel>
              </StackPanel>
            </Button>

            <Button x:Name="Item2" Click="OnItemClick" Tag="1" HorizontalAlignment="Stretch"
                    Padding="12" CornerRadius="6">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Border x:Name="Rect2" Width="48" Height="48" CornerRadius="8" Background="Blue" />
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="Blue Item" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="Tap to view details" FontSize="12" Opacity="0.5" />
                </StackPanel>
              </StackPanel>
            </Button>

            <Button x:Name="Item3" Click="OnItemClick" Tag="2" HorizontalAlignment="Stretch"
                    Padding="12" CornerRadius="6">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Border x:Name="Rect3" Width="48" Height="48" CornerRadius="8" Background="Purple" />
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="Purple Item" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="Tap to view details" FontSize="12" Opacity="0.5" />
                </StackPanel>
              </StackPanel>
            </Button>

            <Button x:Name="Item4" Click="OnItemClick" Tag="3" HorizontalAlignment="Stretch"
                    Padding="12" CornerRadius="6">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Border x:Name="Rect4" Width="48" Height="48" CornerRadius="8" Background="Teal" />
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="Teal Item" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="Tap to view details" FontSize="12" Opacity="0.5" />
                </StackPanel>
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- Detail panel -->
          <Grid x:Name="DetailPanel" IsVisible="False" RowDefinitions="Auto,Auto,*">
            <Button Grid.Row="0" Content="← Back" Click="OnBackClick"
                    Margin="0,0,0,16" HorizontalAlignment="Left" />
            <Border x:Name="DetailRect" Grid.Row="1"
                    Width="200" Height="200" CornerRadius="16"
                    HorizontalAlignment="Center" Margin="0,0,0,16" />
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Spacing="4">
              <TextBlock x:Name="DetailTitle" FontSize="24" FontWeight="Bold"
                         HorizontalAlignment="Center" />
              <TextBlock x:Name="DetailSubtitle" FontSize="14" Opacity="0.6"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </DockPanel>
  </DockPanel>
</UserControl>
