<Styles x:Class="Avalonia.Themes.Fluent2.Fluent2Theme"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fluent="using:Avalonia.Themes.Fluent2"
        xmlns:accents="using:Avalonia.Themes.Fluent2.Accents"
        xmlns:strings="using:Avalonia.Themes.Fluent2.Strings">
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Keep custom palettes higher priority than default BaseColorsPalette and SystemAccentColors
             As that's an only place for user to redefine palette in a good way -->
        <ResourceInclude Source="/Accents/BaseColorsPalette.xaml" />
        <ResourceInclude Source="/Accents/Fluent2ColorPalette.xaml" />
        <accents:SystemAccentColors />
        <fluent:ColorPaletteResourcesCollection />

        <!-- Invariant strings, then culture-aware overrides: the provider is merged after the
             invariant dictionary so a translation for the current UI culture wins, and it
             returns false for untranslated cultures, falling back to invariant. -->
        <ResourceInclude Source="/Strings/InvariantResources.xaml" />
        <strings:LocalizedStringsProvider />

        <!-- Resources and brushes will be merged into current dictionary for slightly better
             performance and possible optimizations (MergeResourceInclude must come last) -->
        <MergeResourceInclude Source="/Accents/BaseResources.xaml" />
        <MergeResourceInclude Source="/Accents/Fluent2TokenResources.xaml" />
        <MergeResourceInclude Source="/Accents/FluentControlResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
      
      <!-- These are not part of MergedDictionaries so we can add or remove them easier -->
      <ResourceInclude x:Key="CompactStyles" Source="/DensityStyles/Compact.xaml" />
    </ResourceDictionary>
  </Styles.Resources>
  
  <StyleInclude Source="/Controls/FluentControls.xaml" />
</Styles>
