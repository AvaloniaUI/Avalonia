          <GradientStop Offset="1.0" Color="{StaticResource ControlStrokeColorDefault}" />
        </LinearGradientBrush.GradientStops>
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="TextControlElevationBorderFocusedBrush" StartPoint="0,0" EndPoint="0,2" TransformOrigin="50%,50%">
        <LinearGradientBrush.Transform>
          <ScaleTransform ScaleY="-1" />
        </LinearGradientBrush.Transform>
        <LinearGradientBrush.GradientStops>
          <GradientStop Offset="1.0" Color="{DynamicResource SystemAccentColorDark1}" />
          <GradientStop Offset="1.0" Color="{StaticResource ControlStrokeColorDefault}" />
        </LinearGradientBrush.GradientStops>
      </LinearGradientBrush>

      <!-- Acrylic surfaces as solid fallback colors. -->
      <SolidColorBrush x:Key="AcrylicBackgroundFillColorDefaultBrush" Color="#F9F9F9" />
