<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal">
  <Design.PreviewWith>
    <Border Padding="20">
      <StackPanel Spacing="20">
        <CalendarButton Content="Jan" />
      </StackPanel>
    </Border>
  </Design.PreviewWith>

  <!-- WinUI reference: CalendarView_themeresources.xaml (Fluent v2 resources), tag winui3/release/1.5.2.
       Month/year items follow the same treatment as day items (transparent rest, subtle-fill
       hover/press, accent fill for the highlighted item) but, unlike the circular day items, they
       stretch to fill their grid cells in Avalonia, so a 4px rounded rect is used instead of a
       circle. The corner radius and font size are not exposed as WinUI theme resources and are
       approximated here from the WinUI visuals. -->
  <CornerRadius x:Key="CalendarViewMonthYearItemCornerRadius">4</CornerRadius>
  <x:Double x:Key="CalendarViewMonthYearItemFontSize">14</x:Double>

  <ControlTheme x:Key="{x:Type CalendarButton}" TargetType="CalendarButton">
    <Setter Property="ClickMode" Value="Release" />
    <Setter Property="MinWidth" Value="56" />
    <Setter Property="MinHeight" Value="48" />
    <Setter Property="Margin" Value="1" />
    <Setter Property="Padding" Value="0,0,0,0" />
    <!--These are actually set on the CalendarView in WinUI-->
    <Setter Property="Foreground" Value="{DynamicResource CalendarViewCalendarItemForeground}" />
    <Setter Property="Background" Value="{DynamicResource CalendarViewCalendarItemRevealBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CalendarViewCalendarItemRevealBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CalendarViewMonthYearItemCornerRadius}" />
    <Setter Property="FontSize" Value="{DynamicResource CalendarViewMonthYearItemFontSize}" />
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <!-- Fill backplate: carries the subtle-fill hover/press states and the accent fill of
               the highlighted (selected) item. -->
          <Border Name="Root"
                  Background="{TemplateBinding Background}"
                  BackgroundSizing="OuterBorderEdge"
                  BorderThickness="0"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  ClipToBounds="True">
            <Border.Transitions>
              <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.083" />
              </Transitions>
            </Border.Transitions>

            <ContentPresenter Name="PART_ContentPresenter"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              Content="{TemplateBinding Content}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Margin="{TemplateBinding Padding}" />
          </Border>

          <!-- Selection ring: drawn on top of the backplate at the full item bounds. -->
          <Border Name="Border"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  CornerRadius="{TemplateBinding CornerRadius}" />
        </Panel>
      </ControlTemplate>
    </Setter>

    <!-- Hover/press are subtle fills in Windows 11. This theme has no hover-fill alias for
         CalendarView (WinUI 2 used a reveal border instead), so Fluent 2 tokens are referenced directly. -->
    <Style Selector="^:pointerover /template/ Border#Root">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
    </Style>

    <Style Selector="^:pressed /template/ Border#Root">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
    </Style>

    <!-- WinUI calls this OutOfFocus (out of scope). Windows 11 drops the gray backplate and dims the
         text only. CalendarViewOutOfScopeForeground still aliases a legacy WinUI 2 brush in this theme,
         so the Fluent 2 token is referenced directly. -->
    <Style Selector="^:inactive /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>

    <!-- :selected marks the month/year that contains the current date; WinUI gives it the same
         filled-accent treatment as the today day item. There is no CalendarViewTodayBackground alias
         in this theme, so the Fluent 2 accent fill tokens are referenced directly. -->
    <Style Selector="^:selected">
      <Style Selector="^ /template/ Border#Root">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
      </Style>

      <Style Selector="^ /template/ Border#Border">
        <Setter Property="BorderBrush" Value="{DynamicResource CalendarViewSelectedBorderBrush}" />
      </Style>

      <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource CalendarViewTodayForeground}" />
        <Setter Property="FontWeight" Value="{DynamicResource CalendarViewTodayFontWeight}" />
      </Style>

      <Style Selector="^:pointerover">
        <Style Selector="^ /template/ Border#Border">
          <Setter Property="BorderBrush" Value="{DynamicResource CalendarViewSelectedHoverBorderBrush}" />
        </Style>
        <Style Selector="^ /template/ Border#Root">
          <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
        </Style>
      </Style>

      <Style Selector="^:pressed">
        <Style Selector="^ /template/ Border#Border">
          <Setter Property="BorderBrush" Value="{DynamicResource CalendarViewSelectedPressedBorderBrush}" />
        </Style>
        <Style Selector="^ /template/ Border#Root">
          <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
        </Style>
      </Style>
    </Style>

    <Style Selector="^:blackout /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource CalendarViewBlackoutForeground}" />
    </Style>

    <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource CalendarViewWeekDayForegroundDisabled}" />
    </Style>
  </ControlTheme>
</ResourceDictionary>
