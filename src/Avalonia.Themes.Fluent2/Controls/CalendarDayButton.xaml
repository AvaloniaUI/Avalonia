<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal">
  <Design.PreviewWith>
    <Border Padding="20">
      <StackPanel Spacing="20">
        <CalendarDayButton Content="8" />
      </StackPanel>
    </Border>
  </Design.PreviewWith>

  <!-- WinUI reference: CalendarView_themeresources.xaml (Fluent v2 resources), tag winui3/release/1.5.2.
       Windows 11 day items are circular: rest is transparent with primary text, hover/press are
       subtle-fill circles, today is a filled accent circle with on-accent text, and selection is a
       1px accent ring around a transparent middle. The circular corner radius and the day item font
       size are baked into WinUI's CalendarViewDayItem chrome rather than exposed as theme resources,
       so they are approximated here from the WinUI visuals. -->
  <CornerRadius x:Key="CalendarViewDayItemCornerRadius">20</CornerRadius>
  <x:Double x:Key="CalendarViewDayItemFontSize">14</x:Double>

  <ControlTheme x:Key="{x:Type CalendarDayButton}" TargetType="CalendarDayButton">
    <Setter Property="ClickMode" Value="Release" />
    <Setter Property="MinWidth" Value="40" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Margin" Value="1" />
    <Setter Property="Padding" Value="0,0,0,0" />
    <!--These are actually set on the CalendarView in WinUI-->
    <Setter Property="Foreground" Value="{DynamicResource CalendarViewCalendarItemForeground}" />
    <Setter Property="Background" Value="{DynamicResource CalendarViewCalendarItemRevealBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CalendarViewCalendarItemRevealBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CalendarViewDayItemCornerRadius}" />
    <Setter Property="FontSize" Value="{DynamicResource CalendarViewDayItemFontSize}" />
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <!-- Fill circle: carries the subtle-fill hover/press states and the today accent fill.
               It is inset when today is also selected so the selection ring reads as a ring. -->
          <Border Name="Root"
                  Background="{TemplateBinding Background}"
                  BackgroundSizing="OuterBorderEdge"
                  BorderThickness="0"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  ClipToBounds="True">
            <Border.Transitions>
              <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.083" />
              </Transitions>
            </Border.Transitions>

            <ContentPresenter Name="PART_ContentPresenter"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              Content="{TemplateBinding Content}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Margin="{TemplateBinding Padding}" />

          </Border>

          <!-- Selection ring: drawn on top of the fill circle at the full item bounds. -->
          <Border Name="Border"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  CornerRadius="{TemplateBinding CornerRadius}" />
        </Panel>
      </ControlTemplate>
    </Setter>

    <!-- Hover/press are subtle-fill circles in Windows 11. This theme has no hover-fill alias for
         CalendarView (WinUI 2 used a reveal border instead), so Fluent 2 tokens are referenced directly. -->
    <Style Selector="^:pointerover /template/ Border#Root">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
    </Style>

    <Style Selector="^:pressed /template/ Border#Root">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
    </Style>

    <!-- WinUI calls this OutOfFocus (out of scope). Windows 11 drops the gray backplate and dims the
         text only. CalendarViewOutOfScopeForeground still aliases a legacy WinUI 2 brush in this theme,
         so the Fluent 2 token is referenced directly. -->
    <Style Selector="^:inactive /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>

    <Style Selector="^:selected">
      <Style Selector="^ /template/ Border#Border">
        <Setter Property="BorderBrush" Value="{DynamicResource CalendarViewSelectedBorderBrush}" />
      </Style>
      <Style Selector="^:pointerover /template/ Border#Border">
        <Setter Property="BorderBrush" Value="{DynamicResource CalendarViewSelectedHoverBorderBrush}" />
      </Style>
      <Style Selector="^:pressed /template/ Border#Border">
        <Setter Property="BorderBrush" Value="{DynamicResource CalendarViewSelectedPressedBorderBrush}" />
      </Style>
      <!-- CalendarViewSelectedForeground is not aliased in this theme yet, so the Fluent 2 token
           for accent text is referenced directly. -->
      <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
      </Style>
    </Style>

    <Style Selector="^:today">
      <!-- Today is a filled accent circle. There is no CalendarViewTodayBackground alias in this
           theme, so the Fluent 2 accent fill tokens are referenced directly. -->
      <Style Selector="^ /template/ Border#Root">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
      </Style>
      <Style Selector="^:pointerover /template/ Border#Root">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
      </Style>
      <Style Selector="^:pressed /template/ Border#Root">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
      </Style>
      <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource CalendarViewTodayForeground}" />
        <Setter Property="FontWeight" Value="{DynamicResource CalendarViewTodayFontWeight}" />
      </Style>
      <!-- Today + selected: inset the accent fill so a gap appears between fill and selection ring,
           mimicking the WinUI 3 ring-and-dot treatment. -->
      <Style Selector="^:selected /template/ Border#Root">
        <Setter Property="Margin" Value="3" />
      </Style>
    </Style>

    <Style Selector="^:blackout /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource CalendarViewBlackoutForeground}" />
    </Style>

    <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource CalendarViewWeekDayForegroundDisabled}" />
    </Style>
  </ControlTheme>
</ResourceDictionary>
