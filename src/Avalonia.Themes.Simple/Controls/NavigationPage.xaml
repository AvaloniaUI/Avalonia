<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <Border Width="400" Height="600">
      <NavigationPage />
    </Border>
  </Design.PreviewWith>

