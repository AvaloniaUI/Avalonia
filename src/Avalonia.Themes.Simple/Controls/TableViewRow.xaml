<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal">

  <Thickness x:Key="TableViewRowPadding">2,1</Thickness>

  <ControlTheme x:Key="{x:Type TableViewRow}" TargetType="TableViewRow">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="{DynamicResource TableViewRowPadding}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}"
                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}">
          <TableViewCellsPresenter Name="PART_CellsPresenter" />
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- Disabled -->
    <Style Selector="^:disabled /template/ Border#Border">
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeForegroundLowBrush}" />
    </Style>

    <!-- PointerOver -->
    <Style Selector="^:pointerover /template/ Border#Border">
      <Setter Property="Background" Value="{DynamicResource ThemeControlHighlightMidBrush}" />
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
    </Style>

    <!-- Pressed -->
    <Style Selector="^:pressed /template/ Border#Border">
      <Setter Property="Background" Value="{DynamicResource ThemeControlHighlightHighBrush}" />
      <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
    </Style>

    <!-- Selected -->
    <Style Selector="^:selected">

      <Style Selector="^ /template/ Border#Border">
        <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush4}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
      </Style>

      <!-- Selected Unfocused  -->
      <Style Selector="^:not(:focus) /template/ Border#Border">
        <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush4}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
      </Style>

      <!-- Selected PointerOver  -->
      <Style Selector="^:pointerover /template/ Border#Border">
        <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush3}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
      </Style>

      <!-- Selected Pressed  -->
      <Style Selector="^:pressed /template/ Border#Border">
        <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush2}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
      </Style>

    </Style>

  </ControlTheme>

</ResourceDictionary>
